# ═══════════════════════════════════════════════════
# Cerulean Next — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ═══════════════════════════════════════════════════

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cerulean:cerulean@postgres:5432/cerulean

# ── Redis / Celery ────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Security ──────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
FERNET_KEY=                  # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── AI ────────────────────────────────────────────
ANTHROPIC_API_KEY=           # sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── File storage ──────────────────────────────────
DATA_ROOT=/data/projects     # local filesystem path; absolute
# Optional S3/MinIO (leave blank to use local FS)
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=cerulean

# ── Flower monitoring ─────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# ── App behaviour ─────────────────────────────────
DEBUG=true
LOG_LEVEL=info
AI_MAX_SAMPLE_RECORDS=50     # records sent to Claude for field map analysis
AI_MIN_CONFIDENCE=0.70       # suggestions below this threshold flagged for review
